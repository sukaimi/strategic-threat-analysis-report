# ============================================================
# STAR (Strategic Threat Analysis Report) — Codename MERLION
# Environment Variables
# Copy to .env and fill in your values
# ============================================================

# ── Server ──────────────────────────────────────────────────
NODE_ENV=development
PORT_API=3001
PORT_WS=3002
PORT_FRONTEND=3000

# ── API Authentication ────────────────────────────────────────
# Set a secret key to protect all API endpoints (except /api/health).
# Leave empty for open access in development.
API_KEY=
# Frontend API key (must match API_KEY if set; Next.js client-side convention)
NEXT_PUBLIC_API_KEY=

# ── SQLite ──────────────────────────────────────────────────
SQLITE_DB_PATH=./data/spectre.db

# ── AIS Data (AISStream.io) ────────────────────────────────
# Sign up: https://aisstream.io/
AISSTREAM_API_KEY=

# ── AI Provider Order ──────────────────────────────────────
# Comma-separated list: first = primary, rest = fallbacks
# Options: ollama, deepseek, gemini
# Change this single line to reorder which LLM is tried first
AI_PROVIDER_ORDER=ollama,deepseek,gemini

# ── AI — Ollama / Llama (self-hosted) ──────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ── AI — DeepSeek V3 ──────────────────────────────────────
# Sign up: https://platform.deepseek.com/
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ── AI — Gemini Flash 2.0 ────────────────────────────────
# Sign up: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ── Weather — Open-Meteo (Free, no key needed) ─────────────
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1

# ── Weather — NEA Singapore ─────────────────────────────────
# Free: https://api.data.gov.sg/
NEA_BASE_URL=https://api.data.gov.sg/v1

# ── Flight Data — ADS-B Exchange / OpenSky ──────────────────
# Free: https://www.adsbexchange.com/ or https://opensky-network.org/
ADSB_FI_BASE_URL=https://opendata.adsb.fi/api/v2
OPENSKY_USERNAME=
OPENSKY_PASSWORD=

# ── Port Data — data.gov.sg ─────────────────────────────────
# Free: https://data.gov.sg/
DATAGOV_BASE_URL=https://api.data.gov.sg/v1

# ── Satellite TLE — CelesTrak (Free) ────────────────────────
CELESTRAK_BASE_URL=https://celestrak.org

# ── Aviation — NOTAM / SIGMET ────────────────────────────────
AVIATION_WEATHER_BASE_URL=https://aviationweather.gov/api/data

# ── Obsidian Vault ──────────────────────────────────────────
VAULT_PATH=./vault/star-merlion

# ── Alerts ──────────────────────────────────────────────────
ALERT_WEBHOOK_URL=
ALERT_EMAIL_TO=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── Domain (Production) ─────────────────────────────────────
DOMAIN=localhost
